# Copy to .env on superotter (/home/administrator/kairos/.env) before
# `docker compose up`. Never commit the .env itself.

# FMP — daily-bar source for HTF + BBTC indicators
FMP_API_KEY=

# Shared secret with stockotter's BOT_API_KEY. Generate one identical value
# on both sides with: openssl rand -hex 32
BOT_API_KEY=

# Stockotter Express base URL (defaults to internal LAN IP if unset)
STOCKOTTER_INTERNAL_URL=http://10.209.32.9:5000

# Live mode is gated behind BOTH flags. Leave OFF for Phase 1.
KAIROS_MODE=paper
KAIROS_I_ACCEPT_RISK=false
