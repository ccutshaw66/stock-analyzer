# ─── Required ────────────────────────────────────────────────────────────────

# Polygon.io API key (Stocks Starter + Options Starter recommended, $58/mo).
# Used as the primary data source for quotes, charts, financials, options,
# dividends, splits, and symbol search. Sign up at https://polygon.io/pricing
POLYGON_API_KEY=

# PostgreSQL connection string
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Session secret (any long random string)
SESSION_SECRET=change-me-to-a-long-random-string

# ─── Optional ────────────────────────────────────────────────────────────────

# Stripe (for paid tier features)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PLUS=

# Port the server binds to (default 5000)
PORT=5000

# Production deployment webhook secret (optional)
DEPLOY_WEBHOOK_SECRET=
