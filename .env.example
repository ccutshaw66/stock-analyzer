# ─── Required ────────────────────────────────────────────────────────────────

# Polygon.io API key (Stocks Starter + Options Starter recommended, $58/mo).
# Primary source for quotes, charts, financials, options, dividends, splits,
# and symbol search. Sign up at https://polygon.io/pricing
POLYGON_API_KEY=

# PostgreSQL connection string
DATABASE_URL=postgres://user:pass@host:5432/dbname

# JWT signing secret (any long random string)
JWT_SECRET=change-me-to-a-long-random-string

# ─── Data providers (recommended) ────────────────────────────────────────────

# Financial Modeling Prep Premium ($59/mo). Source for analyst ratings,
# earnings estimates/surprises, insider trading, institutional holdings,
# fundamental screener, and >5y historical bars. Sign up at
# https://site.financialmodelingprep.com/developer/docs/pricing
FMP_API_KEY=

# ─── Server ──────────────────────────────────────────────────────────────────

# Port the server binds to (default 5000)
PORT=5000

# Public URL of the app (used in email links, OAuth redirects, etc.)
APP_BASE_URL=http://localhost:5000

# ─── Billing (Stripe) ────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ELITE_PRICE_ID=

# ─── Mail (SMTP — required for alerts) ───────────────────────────────────────

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@stockotter.ai

# ─── Operations ──────────────────────────────────────────────────────────────

# Production deployment webhook secret (optional)
DEPLOY_WEBHOOK_SECRET=

# Sentry DSN for error tracking (Phase 2)
SENTRY_DSN=
